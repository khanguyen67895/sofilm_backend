{
  "name": "sofilm-backend",
  "version": "0.1.0",
  "private": true,
  "description": "SoFilm backend — NestJS microservices monorepo (apps/ + libs/)",
  "scripts": {
    "build": "nest build",
    "build:all": "node scripts/build-all.js",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "lint:ci": "eslint \"{apps,libs}/**/*.ts\"",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "stack:up": "docker compose --profile apps up -d --build",
    "start:gateway": "nest start gateway --watch",
    "start:auth": "nest start auth --watch",
    "start:user": "nest start user --watch",
    "start:movie": "nest start movie --watch",
    "start:video": "nest start video --watch",
    "start:search": "nest start search --watch",
    "start:history": "nest start history --watch",
    "start:recommendation": "nest start recommendation --watch",
    "start:payment": "nest start payment --watch",
    "start:notification": "nest start notification --watch",
    "start:transcoder": "nest start transcoder --watch",
    "promote-admin": "ts-node -r tsconfig-paths/register apps/auth/src/scripts/promote-admin.script.ts",
    "seed:genres": "ts-node -r tsconfig-paths/register apps/movie/src/scripts/seed-genres.script.ts",
    "seed:plans": "ts-node -r tsconfig-paths/register apps/payment/src/scripts/seed-plans.script.ts",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.669.0",
    "@aws-sdk/s3-request-presigner": "^3.669.0",
    "@elastic/elasticsearch": "^8.15.0",
    "@nestjs/axios": "^3.1.1",
    "@nestjs/bullmq": "^10.2.1",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/typeorm": "^10.0.2",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.15.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "nest-winston": "^1.9.7",
    "nodemailer": "^6.9.15",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.26",
    "@types/jest": "^29.5.13",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.16.10",
    "@types/nodemailer": "^6.4.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  }
}
