# ── Service ports (used by each app's own main.ts) ──────────────────────────
GATEWAY_PORT=3000
AUTH_PORT=3001
USER_PORT=3002
MOVIE_PORT=3003
VIDEO_PORT=3004
SEARCH_PORT=3005
HISTORY_PORT=3006
RECOMMENDATION_PORT=3007
PAYMENT_PORT=3008
NOTIFICATION_PORT=3009
# transcoder has no HTTP port — it's a BullMQ worker only

# ── Gateway → downstream service base URLs (HTTP reverse-proxy targets) ────
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
MOVIE_SERVICE_URL=http://localhost:3003
VIDEO_SERVICE_URL=http://localhost:3004
SEARCH_SERVICE_URL=http://localhost:3005
HISTORY_SERVICE_URL=http://localhost:3006
RECOMMENDATION_SERVICE_URL=http://localhost:3007
PAYMENT_SERVICE_URL=http://localhost:3008
NOTIFICATION_SERVICE_URL=http://localhost:3009

# ── Postgres (one logical database per service, same instance in dev) ─────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=sofilm
DB_PASSWORD=sofilm
AUTH_DB_NAME=auth_db
USER_DB_NAME=user_db
MOVIE_DB_NAME=movie_db
VIDEO_DB_NAME=video_db
HISTORY_DB_NAME=history_db
PAYMENT_DB_NAME=payment_db
NOTIFICATION_DB_NAME=notification_db

# ── Redis (cache, session, OTP, trending, recommendation cache, search cache) ─
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# ── OTP ─────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# ── Social login (OAuth) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── Object storage (S3-compatible — MinIO in dev) ──────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=sofilm
S3_SECRET_KEY=sofilm123
S3_BUCKET=sofilm-media
S3_FORCE_PATH_STYLE=true
CDN_BASE_URL=http://localhost:9000/sofilm-media

# ── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200

# ── Mail (SMTP — MailHog in dev) ─────────────────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=SoFilm <no-reply@sofilm.dev>

# ── Push / SMS (stub providers — plug real credentials in production) ──────
FCM_SERVER_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Payment gateways ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=

# ── Rate limiting (gateway) ──────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
