    "auth-lib": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": { "tsConfigPath": "libs/auth/tsconfig.lib.json" }
    },
    "logger": {
      "type": "library",
      "root": "libs/logger",
      "entryFile": "index",
      "sourceRoot": "libs/logger/src",
      "compilerOptions": { "tsConfigPath": "libs/logger/tsconfig.lib.json" }
    },
    "config": {
      "type": "library",
      "root": "libs/config",
      "entryFile": "index",
      "sourceRoot": "libs/config/src",
      "compilerOptions": { "tsConfigPath": "libs/config/tsconfig.lib.json" }
    }
  }
}
